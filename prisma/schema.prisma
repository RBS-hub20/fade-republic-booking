// Prisma schema for QuantumX Global Markets.
//
// Database: PostgreSQL (works locally via Docker and in production on Vercel
// Postgres / Neon / Supabase / any Postgres).
//   - DATABASE_URL: primary connection string (pooled is fine for the app).
//   - The schema is pushed with `prisma db push`; for pooled providers the
//     push uses DIRECT_URL when set (see scripts/db-deploy.mjs).
//
// The string fields marked "enum:" are constrained at the app layer in
// src/lib/constants.ts (single source of truth for allowed values). They are
// kept as strings so the model stays portable; you may promote them to native
// Postgres `enum`s later if desired.

generator client {
  provider = "prisma-client-js"
  // `prisma generate` runs on every build (see scripts/db-deploy.mjs), so the
  // "native" engine is produced on the same platform it runs on — including
  // Vercel's serverless runtime. Add an explicit `binaryTargets` here only if
  // you build and deploy on different OSes.
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  // Salted password hash (scrypt) — see src/lib/password.ts.
  passwordHash  String
  // enum: Role — admin | client
  role          String   @default("client")
  emailVerified Boolean  @default(false)
  // Client users are linked to their trading account.
  clientId      String?  @unique
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tokens        AuthToken[]

  // --- Referral program -----------------------------------------------------
  // Unique shareable code (first 4 letters of name + 3 digits, e.g. RENZ123).
  referralCode      String?  @unique
  // The user who referred THIS user (set at signup via ?ref=).
  referredById      String?
  referredBy        User?    @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals         User[]   @relation("UserReferrals")
  // --- Genealogy / lineage (materialized-path) ------------------------------
  // Slash-joined ancestor ids from root → direct sponsor (excludes self); null
  // for a root user. depth = number of ancestors; rootSponsorId = topmost.
  referralPath      String?
  referralDepth     Int      @default(0)
  rootSponsorId     String?
  // --- Username (separate from referralCode; claim-once) --------------------
  // Always stored lowercase; case-insensitive uniqueness via a LOWER() index
  // (see username-schema). usernameSet locks it after the one allowed change.
  username          String?
  usernameSet       Boolean  @default(false)
  // Auto-assigned avatar (permanent). gender drives which of the 10 SVGs.
  gender            String   @default("male")
  avatarType        String?
  // Withdrawable, settled referral commission (separate from trading balance).
  commissionBalance Float    @default(0)
  commissionsEarned    ReferralCommission[]   @relation("CommissionEarner")
  commissionWithdrawals CommissionWithdrawal[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([referralPath])
  @@index([referralDepth])
  @@index([rootSponsorId])
  // Sponsor/parent index powering the genealogy downline queries.
  @@index([referredById])
}

// One commission per referred user (first QX Tier activation only).
model ReferralCommission {
  id             String    @id @default(cuid())
  referrerId     String
  referrer       User      @relation("CommissionEarner", fields: [referrerId], references: [id], onDelete: Cascade)
  // The referred user whose first package generated this commission (unique).
  referredUserId String    @unique
  referredName   String
  // e.g. "Silver $100" — the tier the referral activated.
  packageLabel   String
  packageAmount  Float
  commission     Float
  // enum: PENDING | PAID  (auto-settles to PAID after 24h)
  status         String    @default("PENDING")
  createdAt      DateTime  @default(now())
  paidAt         DateTime?

  @@index([referrerId])
}

// AI support chat transcript (both sides), retained for admin review.
/// Uploaded USDT proof screenshots/PDFs (withdrawal payout proof by admins,
/// deposit proof by clients), stored in Vercel Blob. `url` is the (unguessable)
/// blob URL — never sent to the browser; admins view via an auth-gated stream.
model ProofFile {
  id           String   @id @default(cuid())
  kind         String // "withdrawal" | "deposit"
  refId        String // withdrawal.id or transaction.id
  uploaderId   String?
  clientId     String?
  network      String?
  txHash       String?
  url          String
  pathname     String
  contentType  String
  size         Int      @default(0)
  originalName String?
  createdAt    DateTime @default(now())

  @@index([kind, refId])
  @@index([createdAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  clientId  String?
  // enum: 'user' | 'assistant'
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Earnings withdrawal request (Available Withdrawal pool = daily P/L + referral
// commissions). Manually processed by an admin: funds are sent from an external
// wallet and the on-chain TX hash is recorded here. 3% fee → platform revenue.
model Withdrawal {
  id            String    @id @default(cuid())
  userId        String
  clientId      String?
  amount        Float
  fee           Float
  receiveAmount Float
  // enum: USDT_BEP20 | USDT_TRC20
  network       String
  address       String
  // enum: pending | processing | completed | rejected
  status        String    @default("pending")
  txHash        String?
  rejectReason  String?
  adminId       String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId, status])
  @@index([status])
}

// A user's action on a MATURED capital deposit (6-month time lock).
//   renewed   → extends the deposit's maturity by another 6 months
//   withdrawn → releases the principal into the Available Withdrawal pool
model CapitalAction {
  id            String   @id @default(cuid())
  transactionId String
  userId        String
  clientId      String?
  // enum: renewed | withdrawn
  action        String
  amount        Float    @default(0)
  createdAt     DateTime @default(now())

  @@index([transactionId])
  @@index([userId])
}

// 2nd-level unlock status per user (needs 3+ qualifying direct referrals).
model UserUnlock {
  userId             String    @id
  level2Unlocked     Boolean   @default(false)
  unlockedAt         DateTime?
  activeDirectsCount Int       @default(0)
  updatedAt          DateTime  @updatedAt
}

// 2nd-level (indirect) commission — paid once per source user's first deposit,
// to the nearest UNLOCKED upline above the direct referrer.
model Level2Commission {
  id               String   @id @default(cuid())
  earnerId         String   // who gets paid
  sourceUserId     String   @unique // who deposited (first deposit only)
  directUplineId   String?  // middle man (the source's direct referrer)
  depositAmount    Float
  commissionRate   Float
  commissionAmount Float
  uplineTierAtTime String?
  createdAt        DateTime @default(now())

  @@index([earnerId])
  @@index([sourceUserId])
}

// Monthly 5% bonus on the previous calendar month's Daily P/L of a user's
// qualifying direct referrals. One row per user per month (idempotent).
model MonthlyBonus {
  id             String   @id @default(cuid())
  userId         String
  monthYear      String   // 'YYYY-MM'
  totalDirectsPl Float
  bonusRate      Float    @default(5)
  bonusAmount    Float
  directsCount   Int
  paidAt         DateTime @default(now())

  @@unique([userId, monthYear])
  @@index([userId])
}

// A payout request that draws down commissionBalance only.
model CommissionWithdrawal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float
  address   String
  network   String
  // enum: PENDING | PAID | REJECTED
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuthToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // enum: AuthTokenType — EMAIL_VERIFY | PASSWORD_RESET
  type      String
  // sha256 of the raw token (raw token is only ever sent in the email link).
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Client {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String?
  accountNumber  String   @unique
  initialDeposit Float    @default(0)
  startDate      DateTime
  // enum: ClientStatus — ACTIVE | PAUSED | CLOSED
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user              User?
  transactions      Transaction[]
  dailyPerformances DailyPerformance[]
}

model Transaction {
  id       String   @id @default(cuid())
  clientId String
  date     DateTime
  // enum: TransactionType — DEPOSIT | WITHDRAWAL
  type     String
  amount   Float
  // enum: TransactionMethod — BANK | CRYPTO | OTC
  method   String   @default("BANK")
  // enum: TransactionStatus — PENDING | APPROVED
  status   String   @default("APPROVED")
  notes    String?
  createdAt DateTime @default(now())

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([date])
}

model DailyPerformance {
  id           String   @id @default(cuid())
  clientId     String
  date         DateTime
  dailyPercent Float
  // Balance at end of day, after applying dailyPercent to the running equity.
  balanceEOD   Float
  pnlUsd       Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())

  client       Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date])
  @@index([clientId])
  @@index([date])
}
