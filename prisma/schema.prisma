// Prisma schema for QuantumX Global Markets.
//
// Database: PostgreSQL (works locally via Docker and in production on Vercel
// Postgres / Neon / Supabase / any Postgres).
//   - DATABASE_URL: primary connection string (pooled is fine for the app).
//   - The schema is pushed with `prisma db push`; for pooled providers the
//     push uses DIRECT_URL when set (see scripts/db-deploy.mjs).
//
// The string fields marked "enum:" are constrained at the app layer in
// src/lib/constants.ts (single source of truth for allowed values). They are
// kept as strings so the model stays portable; you may promote them to native
// Postgres `enum`s later if desired.

generator client {
  provider = "prisma-client-js"
  // `prisma generate` runs on every build (see scripts/db-deploy.mjs), so the
  // "native" engine is produced on the same platform it runs on — including
  // Vercel's serverless runtime. Add an explicit `binaryTargets` here only if
  // you build and deploy on different OSes.
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  // Salted password hash (scrypt) — see src/lib/password.ts.
  passwordHash  String
  // enum: Role — admin | client
  role          String   @default("client")
  emailVerified Boolean  @default(false)
  // Client users are linked to their trading account.
  clientId      String?  @unique
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tokens        AuthToken[]

  // --- Referral program -----------------------------------------------------
  // Unique shareable code (first 4 letters of name + 3 digits, e.g. RENZ123).
  referralCode      String?  @unique
  // The user who referred THIS user (set at signup via ?ref=).
  referredById      String?
  referredBy        User?    @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals         User[]   @relation("UserReferrals")
  // Withdrawable, settled referral commission (separate from trading balance).
  commissionBalance Float    @default(0)
  commissionsEarned    ReferralCommission[]   @relation("CommissionEarner")
  commissionWithdrawals CommissionWithdrawal[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// One commission per referred user (first QX Tier activation only).
model ReferralCommission {
  id             String    @id @default(cuid())
  referrerId     String
  referrer       User      @relation("CommissionEarner", fields: [referrerId], references: [id], onDelete: Cascade)
  // The referred user whose first package generated this commission (unique).
  referredUserId String    @unique
  referredName   String
  // e.g. "Silver $100" — the tier the referral activated.
  packageLabel   String
  packageAmount  Float
  commission     Float
  // enum: PENDING | PAID  (auto-settles to PAID after 24h)
  status         String    @default("PENDING")
  createdAt      DateTime  @default(now())
  paidAt         DateTime?

  @@index([referrerId])
}

// A payout request that draws down commissionBalance only.
model CommissionWithdrawal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float
  address   String
  network   String
  // enum: PENDING | PAID | REJECTED
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuthToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // enum: AuthTokenType — EMAIL_VERIFY | PASSWORD_RESET
  type      String
  // sha256 of the raw token (raw token is only ever sent in the email link).
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Client {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String?
  accountNumber  String   @unique
  initialDeposit Float    @default(0)
  startDate      DateTime
  // enum: ClientStatus — ACTIVE | PAUSED | CLOSED
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user              User?
  transactions      Transaction[]
  dailyPerformances DailyPerformance[]
}

model Transaction {
  id       String   @id @default(cuid())
  clientId String
  date     DateTime
  // enum: TransactionType — DEPOSIT | WITHDRAWAL
  type     String
  amount   Float
  // enum: TransactionMethod — BANK | CRYPTO | OTC
  method   String   @default("BANK")
  // enum: TransactionStatus — PENDING | APPROVED
  status   String   @default("APPROVED")
  notes    String?
  createdAt DateTime @default(now())

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([date])
}

model DailyPerformance {
  id           String   @id @default(cuid())
  clientId     String
  date         DateTime
  dailyPercent Float
  // Balance at end of day, after applying dailyPercent to the running equity.
  balanceEOD   Float
  pnlUsd       Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())

  client       Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date])
  @@index([clientId])
  @@index([date])
}
