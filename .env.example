# Copy to .env for local development.
#
# PostgreSQL connection string. For local dev with the bundled docker-compose:
DATABASE_URL="postgresql://quantumx:quantumx@localhost:5432/quantumx?schema=public"

# Secret used to sign session cookies (HMAC). REQUIRED in production — set a long
# random value in your host env. If unset, a dev fallback is used.
# SESSION_SECRET="change-me-to-a-long-random-string"

# --- Live market ticker (public homepage) ---
# All optional — the ticker uses free public endpoints with no key by default.
# A CoinGecko demo key improves crypto rate limits; endpoint overrides are for
# self-hosting a proxy/mirror.
# COINGECKO_API_KEY="CG-xxxxxxxx"
# COINGECKO_API_URL="https://api.coingecko.com/api/v3"
# YAHOO_FINANCE_URL="https://query1.finance.yahoo.com"

# --- Deposit gateway (crypto receive wallets) ---
# Public receive addresses shown to clients for USDT deposits. Defaults to the
# current QuantumX wallets if unset. Rotate here without a code change.
# DEPOSIT_USDT_BEP20_ADDRESS="0x57CaA8Cf4658bA49139f4e7cB2D2EBB8101C83c3"
# DEPOSIT_USDT_TRC20_ADDRESS="TNAnmDBcmmgdiAAX6GgGqV63RCrm2aqrqD"
# Enable the Bank transfer option (shown as "coming soon" until true):
# BANK_DEPOSITS_ENABLED="false"

# --- On-chain deposit auto-verification (poller / Vercel Cron) ---
# The /api/deposits/verify route matches a pending USDT deposit's TxID on-chain
# and auto-approves it. Runs on a Vercel Cron (vercel.json) and via the admin
# "Verify on-chain" button.
# CRON_SECRET="a-long-random-string"        # Vercel sends it as Bearer auth to the cron
# BSCSCAN_API_KEY="your-bscscan-key"        # required for BEP20 checks (free: bscscan.com/myapikey)
# TRONGRID_API_KEY="your-trongrid-key"      # optional, raises TRC20 rate limits
# MIN_CONFIRMATIONS_BEP20="6"               # confirmations required before crediting BEP20
# USDT_BEP20_CONTRACT / USDT_TRC20_CONTRACT # override token contracts (defaults are USDT)

# --- Admin bootstrap ---
# If ADMIN_PASSWORD is set, the admin account is created OR reset to this
# password on every deploy (recovers a mismatched/legacy hash and lets you
# control the admin credentials from env). If unset, a default admin is created
# only when missing (admin@quantumxglobal.com / admin123).
# ADMIN_EMAIL="admin@quantumxglobal.com"
# ADMIN_PASSWORD="choose-a-strong-admin-password"

# --- Email (verification + password reset) ---
# Optional. Without a provider, links are logged to the server console / shown as
# a dev link locally. To actually send email, use Resend (https://resend.com):
# RESEND_API_KEY="re_xxxxxxxx"
# EMAIL_FROM="QuantumX Global Markets <noreply@yourdomain.com>"
# Public base URL used to build links in emails (auto-detected on Vercel):
# APP_URL="https://your-app.vercel.app"

# Optional: a DIRECT (non-pooled) connection string used only for `prisma db push`.
# Set this when DATABASE_URL points at a connection pooler (pgbouncer), e.g.
# Vercel Postgres or Neon pooled endpoints. Leave unset otherwise.
# DIRECT_URL="postgresql://user:password@host:5432/db?schema=public"

# --- Production (Vercel) ---
# Set DATABASE_URL (and optionally DIRECT_URL) in your Vercel Project → Settings
# → Environment Variables. Examples:
#   Neon:            postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
#   Vercel Postgres: use POSTGRES_PRISMA_URL as DATABASE_URL and
#                    POSTGRES_URL_NON_POOLING as DIRECT_URL.
