    "lucide-react": "^0.460.0",
    "next": "14.2.21",
    "papaparse": "^5.4.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.2"
  },
