{
  "name": "@lola/server",
  "version": "0.1.0",
  "description": "Lola orchestration layer — provider adapters, conversation engine, API.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/dev-server.ts",
    "start": "node dist/dev-server.js",
    "build": "tsc -p tsconfig.json",
