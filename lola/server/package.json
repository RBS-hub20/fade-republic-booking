    "test:watch": "vitest"
  },
  "dependencies": {
    "@lola/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
