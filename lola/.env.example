# ─────────────────────────────────────────────────────────────────────────────
# Lola — server environment.  Copy to `.env` for local dev (never commit `.env`).
# All secrets live server-side ONLY. The client never receives an API key.
# ─────────────────────────────────────────────────────────────────────────────

# Local dev server port.
PORT=4000

# Phase 1 ships stub providers. Set to 1 only once live adapters exist (Phase 2+)
# AND the matching key below is set. Until then, leave unset/0.
LOLA_LIVE_PROVIDERS=0

# ── Conversation engine (Anthropic Claude) ──────────────────────────────────
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6 for conversation.
LOLA_LLM_MODEL=claude-sonnet-4-6

# ── Speech-to-text (OpenAI Whisper) ─────────────────────────────────────────
OPENAI_API_KEY=

# ── Text-to-speech (ElevenLabs) ─────────────────────────────────────────────
ELEVENLABS_API_KEY=
# Optional default Tagalog/multilingual voice id.
LOLA_TTS_VOICE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Mobile app (Expo) — these are PUBLIC by design (no secrets here).
#   Set in apps/mobile/.env or your Expo config.
# EXPO_PUBLIC_API_URL=http://localhost:4000
# ─────────────────────────────────────────────────────────────────────────────
